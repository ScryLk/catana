# Copie para .env e preencha com valores reais (nunca commite o .env).
# Gere uma SECRET_KEY nova e forte (>= 50 chars). Nao reutilize a antiga.
SECRET_KEY=

# postgres://USUARIO:SENHA@HOST:5432/BANCO   (use @db: no Docker)
DATABASE_URL=psql://root:root@localhost:5432/catana_db

# DEBUG=True em dev, False em producao.
DEBUG=True

# Producao (DEBUG=False): hosts e origens permitidos, separados por virgula.
# ALLOWED_HOSTS=api.seudominio.com
# CORS_ALLOWED_ORIGINS=https://app.seudominio.com
