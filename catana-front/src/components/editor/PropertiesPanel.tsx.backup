import { type FC, useState } from 'react';
import { useEditorStore } from '../../store/editorStore';
import { useAssetStore } from '../../store/assetStore';
import { FiTrash2, FiCopy, FiChevronDown, FiChevronUp, FiScissors, FiLoader } from 'react-icons/fi';
import { ImageSelector } from './ImageSelector';
import { imageProcessingService } from '../../services/imageProcessingService';

export const PropertiesPanel: FC = () => {
  const { getCurrentPage, selectedElementId, updateElement, deleteElement, duplicateElement, updateElementStyle } = useEditorStore();
  const { getAsset, getAssetByUrl } = useAssetStore();
  const currentPage = getCurrentPage();
  const selectedElement = currentPage?.elements.find((el) => el.id === selectedElementId);
  const [isProcessing, setIsProcessing] = useState(false);

  // Accordion states
  const [openSections, setOpenSections] = useState({
    transform: true,
    appearance: true,
    info: false,
    actions: true,
  });

  const toggleSection = (section: keyof typeof openSections) => {
    setOpenSections(prev => ({ ...prev, [section]: !prev[section] }));
  };

  const handleRemoveBackground = async () => {
    if (!selectedElement) return;

    // Determinar a URL da imagem
    let imageUrl = '';
    if (selectedElement.content?.imageUrl) {
      imageUrl = selectedElement.content.imageUrl;
    } else if (selectedElement.imageUrl) {
      imageUrl = selectedElement.imageUrl;
    } else if (selectedElement.content?.src) {
      imageUrl = selectedElement.content.src;
    }

    if (!imageUrl) {
      console.warn('Nenhuma imagem encontrada para remover fundo');
      return;
    }

    try {
      setIsProcessing(true);
      const processedUrl = await imageProcessingService.removeBackground(imageUrl);

      // Atualizar o elemento com a nova imagem
      if (selectedElement.content?.imageUrl) {
        updateElement(selectedElement.id, { content: { ...selectedElement.content, imageUrl: processedUrl } });
      } else if (selectedElement.imageUrl) {
        updateElement(selectedElement.id, { imageUrl: processedUrl });
      } else if (selectedElement.content?.src) {
        updateElement(selectedElement.id, { content: { ...selectedElement.content, src: processedUrl } });
      } else {
        // Fallback: se não tinha propriedade definida, define em content.imageUrl
        updateElement(selectedElement.id, { content: { ...selectedElement.content, imageUrl: processedUrl } });
      }
    } catch (error) {
      console.error('Failed to remove background:', error);
      alert('Falha ao remover o fundo da imagem. Tente novamente.');
    } finally {
      setIsProcessing(false);
    }
  };

  if (!selectedElement) {
    return (
      <div className="h-full flex flex-col items-center justify-center p-6 text-center">
        <div className="w-16 h-16 bg-zinc-100 dark:bg-zinc-800 rounded-2xl flex items-center justify-center mb-4">
          <svg className="w-8 h-8 text-zinc-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122" />
          </svg>
        </div>
        <p className="text-zinc-600 dark:text-zinc-400 text-sm font-medium">Selecione um elemento</p>
        <p className="text-zinc-400 dark:text-zinc-500 text-xs mt-1">Clique em um elemento do canvas para editar</p>
      </div>
    );
  }

  return (
    <div className="p-4 space-y-4 pb-8">
      {/* Element Info */}
      <div className="bg-gradient-to-br from-primary-50 to-accent-50 rounded-xl p-4 border border-primary-100 shadow-soft">
        <h3 className="text-xs font-semibold text-gray-600 uppercase tracking-wide mb-2">Elemento Selecionado</h3>
        <div className="flex items-center gap-3 mb-3">
          <div className="w-12 h-12 bg-gradient-to-br from-primary-500 to-accent-500 rounded-xl flex items-center justify-center text-white font-bold shadow-soft">
            {selectedElement.type.includes('product') ? '📦' : selectedElement.type.includes('text') ? 'A' : '🔲'}
          </div>
          <div className="flex-1 min-w-0">
            <div className="font-semibold text-sm text-gray-900 capitalize">{selectedElement.type.replace(/-/g, ' ')}</div>
            <div className="text-xs text-gray-500 font-mono">{selectedElement.id.slice(0, 8)}...</div>
          </div>
        </div>

        {/* Editable Name */}
        <div>
          <label className="text-xs font-medium text-gray-600 block mb-1">Nome</label>
          <input
            type="text"
            value={selectedElement.name || ''}
            onChange={(e) => updateElement(selectedElement.id, { name: e.target.value })}
            placeholder="Nome do elemento"
            className="w-full px-3 py-2 bg-white border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all"
          />
        </div>
      </div>

      {/* Image Actions */}
      {(selectedElement.type === 'image' || selectedElement.type === 'uploaded-image') && (
        <div className="bg-white rounded-xl border border-gray-200 shadow-soft overflow-hidden">
          <button
            onClick={() => toggleSection('actions')}
            className="w-full px-4 py-3 flex items-center justify-between hover:bg-gray-50 transition-colors"
          >
            <h3 className="text-sm font-semibold text-gray-900">Imagem</h3>
            {openSections.actions ? (
              <FiChevronUp className="w-5 h-5 text-gray-500" />
            ) : (
              <FiChevronDown className="w-5 h-5 text-gray-500" />
            )}
          </button>
          {openSections.actions && (
            <div className="px-4 pb-4 space-y-3">
              {/* Upload de Imagem */}
              <div>
                <label className="block text-xs font-medium text-gray-600 mb-1.5">Upload de Imagem</label>
                <input
                  type="file"
                  accept="image/*"
                  onChange={async (e) => {
                    const file = e.target.files?.[0];
                    if (!file) return;

                    // Criar FormData para enviar a imagem
                    const formData = new FormData();
                    formData.append('file', file);

                    try {
                      // Enviar para o servidor (ajuste a URL conforme necessário)
                      const response = await fetch('http://localhost:3000/upload', {
                        method: 'POST',
                        body: formData,
                      });

                      if (response.ok) {
                        const data = await response.json();
                        const imageUrl = `http://localhost:3000/media/${data.filename}`;

                        // Atualizar o elemento com a URL da imagem
                        if (selectedElement.content?.imageUrl !== undefined) {
                          updateElement(selectedElement.id, {
                            content: { ...selectedElement.content, imageUrl }
                          });
                        } else {
                          updateElement(selectedElement.id, { imageUrl });
                        }
                      } else {
                        alert('Erro ao fazer upload da imagem');
                      }
                    } catch (error) {
                      console.error('Erro ao fazer upload:', error);
                      alert('Erro ao fazer upload da imagem');
                    }
                  }}
                  className="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-primary-50 file:text-primary-700 hover:file:bg-primary-100 file:cursor-pointer cursor-pointer"
                />
                <p className="text-xs text-gray-500 mt-1">
                  Faça upload de uma imagem do seu computador
                </p>
              </div>

              {/* URL da Imagem */}
              <div>
                <label className="block text-xs font-medium text-gray-600 mb-1.5">Ou insira a URL da Imagem</label>
                <input
                  type="text"
                  value={selectedElement.content?.imageUrl || selectedElement.imageUrl || ''}
                  onChange={(e) => {
                    if (selectedElement.content?.imageUrl !== undefined) {
                      updateElement(selectedElement.id, {
                        content: { ...selectedElement.content, imageUrl: e.target.value }
                      });
                    } else {
                      updateElement(selectedElement.id, { imageUrl: e.target.value });
                    }
                  }}
                  placeholder="http://localhost:3000/media/image.png"
                  className="w-full px-3 py-2 bg-gray-50 border border-gray-300 rounded-lg text-sm text-gray-900 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all"
                />
                <p className="text-xs text-gray-500 mt-1">
                  Ex: http://localhost:3000/media/sua-imagem.png
                </p>
              </div>

              {/* Remover Fundo */}
              <button
                onClick={handleRemoveBackground}
                disabled={isProcessing}
                className="w-full flex items-center justify-center gap-2 px-4 py-2 bg-indigo-50 text-indigo-600 hover:bg-indigo-100 rounded-lg transition-colors font-medium text-sm disabled:opacity-50 disabled:cursor-not-allowed"
              >
                {isProcessing ? (
                  <>
                    <FiLoader className="w-4 h-4 animate-spin" />
                    Processando...
                  </>
                ) : (
                  <>
                    <FiScissors className="w-4 h-4" />
                    Remover Fundo
                  </>
                )}
              </button>
            </div>
          )}
        </div>
      )}

      {/* Transformação */}
      <div className="bg-white rounded-xl border border-gray-200 shadow-soft overflow-hidden">
        <button
          onClick={() => toggleSection('transform')}
          className="w-full px-4 py-3 flex items-center justify-between hover:bg-gray-50 transition-colors"
        >
          <h3 className="text-sm font-semibold text-gray-900">Transformação</h3>
          {openSections.transform ? (
            <FiChevronUp className="w-5 h-5 text-gray-500" />
          ) : (
            <FiChevronDown className="w-5 h-5 text-gray-500" />
          )}
        </button>
        {openSections.transform && (
          <div className="px-4 pb-4 space-y-3">
            <div className="grid grid-cols-2 gap-3">
              <div>
                <label className="block text-xs font-medium text-gray-600 mb-1.5">X</label>
                <input
                  type="number"
                  value={Math.round(selectedElement.position.x)}
                  onChange={(e) => updateElement(selectedElement.id, { position: { ...selectedElement.position, x: Number(e.target.value) } })}
                  className="w-full px-3 py-2 bg-gray-50 border border-gray-300 rounded-lg text-sm text-gray-900 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all"
                />
              </div>
              <div>
                <label className="block text-xs font-medium text-gray-600 mb-1.5">Y</label>
                <input
                  type="number"
                  value={Math.round(selectedElement.position.y)}
                  onChange={(e) => updateElement(selectedElement.id, { position: { ...selectedElement.position, y: Number(e.target.value) } })}
                  className="w-full px-3 py-2 bg-gray-50 border border-gray-300 rounded-lg text-sm text-gray-900 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all"
                />
              </div>
              <div>
                <label className="block text-xs font-medium text-gray-600 mb-1.5">Largura</label>
                <input
                  type="number"
                  value={Math.round(selectedElement.size.width)}
                  onChange={(e) => updateElement(selectedElement.id, { size: { ...selectedElement.size, width: Number(e.target.value) } })}
                  className="w-full px-3 py-2 bg-gray-50 border border-gray-300 rounded-lg text-sm text-gray-900 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all"
                />
              </div>
              <div>
                <label className="block text-xs font-medium text-gray-600 mb-1.5">Altura</label>
                <input
                  type="number"
                  value={Math.round(selectedElement.size.height)}
                  onChange={(e) => updateElement(selectedElement.id, { size: { ...selectedElement.size, height: Number(e.target.value) } })}
                  className="w-full px-3 py-2 bg-gray-50 border border-gray-300 rounded-lg text-sm text-gray-900 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all"
                />
              </div>
            </div>
          </div>
        )}
      </div>

      {/* Line Properties */}
      {selectedElement.type === 'shape-line' && (
        <div className="bg-white rounded-xl border border-gray-200 shadow-soft overflow-hidden">
          <button
            onClick={() => toggleSection('appearance')}
            className="w-full px-4 py-3 flex items-center justify-between hover:bg-gray-50 transition-colors"
          >
            <h3 className="text-sm font-semibold text-gray-900">Propriedades da Linha</h3>
            {openSections.appearance ? (
              <FiChevronUp className="w-5 h-5 text-gray-500" />
            ) : (
              <FiChevronDown className="w-5 h-5 text-gray-500" />
            )}
          </button>
          {openSections.appearance && (
            <div className="px-4 pb-4 space-y-3">
              {/* Espessura da Linha */}
              <div>
                <label className="block text-xs font-medium text-gray-600 mb-1.5">Espessura</label>
                <input
                  type="number"
                  min="1"
                  max="50"
                  value={Math.round(selectedElement.size.height)}
                  onChange={(e) => updateElement(selectedElement.id, { size: { ...selectedElement.size, height: Number(e.target.value) } })}
                  className="w-full px-3 py-2 bg-gray-50 border border-gray-300 rounded-lg text-sm text-gray-900 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all"
                />
                <p className="text-xs text-gray-500 mt-1">Altura da linha em pixels</p>
              </div>

              {/* Comprimento da Linha */}
              <div>
                <label className="block text-xs font-medium text-gray-600 mb-1.5">Comprimento</label>
                <input
                  type="number"
                  min="10"
                  max="1000"
                  value={Math.round(selectedElement.size.width)}
                  onChange={(e) => updateElement(selectedElement.id, { size: { ...selectedElement.size, width: Number(e.target.value) } })}
                  className="w-full px-3 py-2 bg-gray-50 border border-gray-300 rounded-lg text-sm text-gray-900 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all"
                />
                <p className="text-xs text-gray-500 mt-1">Largura da linha em pixels</p>
              </div>

              {/* Cor da Linha */}
              <div>
                <label className="block text-xs font-medium text-gray-600 mb-1.5">Cor</label>
                <div className="flex gap-2">
                  <input
                    type="color"
                    value={selectedElement.style.backgroundColor || '#000000'}
                    onChange={(e) => updateElementStyle(selectedElement.id, { backgroundColor: e.target.value })}
                    className="w-12 h-10 rounded-lg border border-gray-300 cursor-pointer"
                  />
                  <input
                    type="text"
                    value={selectedElement.style.backgroundColor || '#000000'}
                    onChange={(e) => updateElementStyle(selectedElement.id, { backgroundColor: e.target.value })}
                    className="flex-1 px-3 py-2 bg-gray-50 border border-gray-300 rounded-lg text-sm text-gray-900 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all font-mono"
                    placeholder="#000000"
                  />
                </div>
              </div>

              {/* Estilo da Linha */}
              <div>
                <label className="block text-xs font-medium text-gray-600 mb-1.5">Estilo</label>
                <select
                  value={selectedElement.style.lineStyle || 'solid'}
                  onChange={(e) => updateElementStyle(selectedElement.id, { lineStyle: e.target.value as 'solid' | 'dashed' | 'dotted' })}
                  className="w-full px-3 py-2 bg-gray-50 border border-gray-300 rounded-lg text-sm text-gray-900 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all"
                >
                  <option value="solid">Sólida</option>
                  <option value="dashed">Tracejada</option>
                  <option value="dotted">Pontilhada</option>
                </select>
              </div>

              {/* Setas */}
              <div className="space-y-2">
                <label className="block text-xs font-medium text-gray-600 mb-1.5">Setas</label>
                <div className="flex gap-3">
                  <label className="flex items-center gap-2 cursor-pointer">
                    <input
                      type="checkbox"
                      checked={selectedElement.style.startArrow || false}
                      onChange={(e) => updateElementStyle(selectedElement.id, { startArrow: e.target.checked })}
                      className="w-4 h-4 text-primary-500 bg-gray-100 border-gray-300 rounded focus:ring-primary-500"
                    />
                    <span className="text-sm text-gray-700">Início</span>
                  </label>
                  <label className="flex items-center gap-2 cursor-pointer">
                    <input
                      type="checkbox"
                      checked={selectedElement.style.endArrow || false}
                      onChange={(e) => updateElementStyle(selectedElement.id, { endArrow: e.target.checked })}
                      className="w-4 h-4 text-primary-500 bg-gray-100 border-gray-300 rounded focus:ring-primary-500"
                    />
                    <span className="text-sm text-gray-700">Fim</span>
                  </label>
                </div>
              </div>

              {/* Tamanho da Seta */}
              {(selectedElement.style.startArrow || selectedElement.style.endArrow) && (
                <div>
                  <label className="block text-xs font-medium text-gray-600 mb-1.5">Tamanho da Seta</label>
                  <input
                    type="number"
                    min="5"
                    max="30"
                    value={selectedElement.style.arrowSize || 10}
                    onChange={(e) => updateElementStyle(selectedElement.id, { arrowSize: Number(e.target.value) })}
                    className="w-full px-3 py-2 bg-gray-50 border border-gray-300 rounded-lg text-sm text-gray-900 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all"
                  />
                  <p className="text-xs text-gray-500 mt-1">Tamanho da ponta da seta em pixels</p>
                </div>
              )}

              {/* Arredondamento */}
              <div>
                <label className="block text-xs font-medium text-gray-600 mb-1.5">Arredondamento</label>
                <input
                  type="number"
                  min="0"
                  max="50"
                  value={selectedElement.style.borderRadius || 0}
                  onChange={(e) => updateElementStyle(selectedElement.id, { borderRadius: Number(e.target.value) })}
                  className="w-full px-3 py-2 bg-gray-50 border border-gray-300 rounded-lg text-sm text-gray-900 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all"
                />
                <p className="text-xs text-gray-500 mt-1">Bordas arredondadas em pixels</p>
              </div>

              {/* Opacidade */}
              <div>
                <div className="flex items-center justify-between mb-2">
                  <label className="block text-xs font-medium text-gray-600">Opacidade</label>
                  <span className="text-xs font-semibold text-gray-900">
                    {Math.round((selectedElement.style.opacity ?? 1) * 100)}%
                  </span>
                </div>
                <input
                  type="range"
                  min="0"
                  max="100"
                  value={(selectedElement.style.opacity ?? 1) * 100}
                  onChange={(e) => updateElementStyle(selectedElement.id, { opacity: Number(e.target.value) / 100 })}
                  className="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-primary-500"
                />
              </div>
            </div>
          )}
        </div>
      )}

      {/* DiPACK Showcase Properties */}
      {selectedElement.type === 'dipack-showcase' && (
        <div className="bg-white rounded-xl p-4 border-2 border-yellow-500 shadow-soft">
          <h3 className="text-xs font-semibold text-yellow-700 mb-3 uppercase tracking-wide flex items-center gap-2">
            📦 Configurações do Mostruário
          </h3>
          <div className="space-y-4">
            <div>
              <label className="block text-xs font-medium text-gray-600 mb-1.5">
                Nome da Linha
              </label>
              <input
                type="text"
                value={selectedElement.content?.lineTitle || 'Linha Exibição'}
                onChange={(e) =>
                  updateElement(selectedElement.id, {
                    content: {
                      ...selectedElement.content,
                      lineTitle: e.target.value,
                    },
                  })
                }
                placeholder="Ex: Linha Exibição"
                className="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-yellow-500 focus:border-yellow-500 transition-all"
              />
              <p className="text-xs text-gray-500 mt-1.5">
                Nome da linha de produtos exibida no topo
              </p>
            </div>

            <div>
              <label className="block text-xs font-medium text-gray-600 mb-2">
                Modelos Rápidos
              </label>
              <div className="grid grid-cols-2 gap-2">
                <button
                  onClick={() =>
                    updateElement(selectedElement.id, {
                      content: { ...selectedElement.content, lineTitle: 'Linha Exibição' },
                    })
                  }
                  className="px-3 py-2 text-xs bg-yellow-50 hover:bg-yellow-100 text-yellow-700 rounded-lg transition-colors border border-yellow-200"
                >
                  🍽️ Gourmet
                </button>
                <button
                  onClick={() =>
                    updateElement(selectedElement.id, {
                      content: { ...selectedElement.content, lineTitle: 'Linha Delivery' },
                    })
                  }
                  className="px-3 py-2 text-xs bg-blue-50 hover:bg-blue-100 text-blue-700 rounded-lg transition-colors border border-blue-200"
                >
                  🚗 Delivery
                </button>
                <button
                  onClick={() =>
                    updateElement(selectedElement.id, {
                      content: { ...selectedElement.content, lineTitle: 'Linha PET' },
                    })
                  }
                  className="px-3 py-2 text-xs bg-green-50 hover:bg-green-100 text-green-700 rounded-lg transition-colors border border-green-200"
                >
                  🐾 PET
                </button>
                <button
                  onClick={() =>
                    updateElement(selectedElement.id, {
                      content: { ...selectedElement.content, lineTitle: 'Linha Industrial' },
                    })
                  }
                  className="px-3 py-2 text-xs bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-lg transition-colors border border-gray-300"
                >
                  🏭 Industrial
                </button>
              </div>
            </div>
          </div>
        </div>
      )}

      {/* DiPACK Footer Properties */}
      {selectedElement.type === 'dipack-footer' && (
        <div className="bg-white rounded-xl p-4 border-2 border-yellow-500 shadow-soft">
          <h3 className="text-xs font-semibold text-yellow-700 mb-3 uppercase tracking-wide flex items-center gap-2">
            📄 Configurações do Rodapé
          </h3>
          <div className="space-y-4">
            <div>
              <label className="block text-xs font-medium text-gray-600 mb-1.5">
                Número da Página
              </label>
              <input
                type="number"
                value={selectedElement.content?.pageNumber || 1}
                onChange={(e) =>
                  updateElement(selectedElement.id, {
                    content: {
                      ...selectedElement.content,
                      pageNumber: Number(e.target.value),
                    },
                  })
                }
                min="1"
                className="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-yellow-500 focus:border-yellow-500 transition-all"
              />
              <p className="text-xs text-gray-500 mt-1.5">
                Número exibido no rodapé da página
              </p>
            </div>
          </div>
        </div>
      )}

      {/* DiPACK Back Cover Properties */}
      {selectedElement.type === 'dipack-back-cover' && (
        <div className="bg-white rounded-xl p-4 border-2 border-yellow-500 shadow-soft">
          <h3 className="text-xs font-semibold text-yellow-700 mb-3 uppercase tracking-wide flex items-center gap-2">
            📕 Configurações da Contracapa
          </h3>
          <div className="space-y-4">
            <div>
              <label className="block text-xs font-medium text-gray-600 mb-1.5">
                URL do QR Code
              </label>
              <input
                type="text"
                value={selectedElement.content?.qrCodeUrl || 'https://lucaskepler.live/'}
                onChange={(e) =>
                  updateElement(selectedElement.id, {
                    content: {
                      ...selectedElement.content,
                      qrCodeUrl: e.target.value,
                    },
                  })
                }
                placeholder="https://lucaskepler.live/"
                className="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-yellow-500 focus:border-yellow-500 transition-all"
              />
              <p className="text-xs text-gray-500 mt-1.5">
                URL para o catálogo digital ou site da empresa
              </p>
            </div>

            <div>
              <label className="block text-xs font-medium text-gray-600 mb-2">
                Modelos Rápidos
              </label>
              <div className="grid grid-cols-2 gap-2">
                <button
                  onClick={() =>
                    updateElement(selectedElement.id, {
                      content: { ...selectedElement.content, qrCodeUrl: 'https://lucaskepler.live/' },
                    })
                  }
                  className="px-3 py-2 text-xs bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors"
                >
                  🌐 Website
                </button>
                <button
                  onClick={() =>
                    updateElement(selectedElement.id, {
                      content: { ...selectedElement.content, qrCodeUrl: 'https://github.com/ScryLk' },
                    })
                  }
                  className="px-3 py-2 text-xs bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors"
                >
                  📄 GitHub
                </button>
                <button
                  onClick={() =>
                    updateElement(selectedElement.id, {
                      content: { ...selectedElement.content, qrCodeUrl: 'https://wa.me/5511999999999' },
                    })
                  }
                  className="px-3 py-2 text-xs bg-green-50 hover:bg-green-100 text-green-700 rounded-lg transition-colors border border-green-200"
                >
                  💬 WhatsApp
                </button>
                <button
                  onClick={() =>
                    updateElement(selectedElement.id, {
                      content: { ...selectedElement.content, qrCodeUrl: 'mailto:contato@lucaskepler.live' },
                    })
                  }
                  className="px-3 py-2 text-xs bg-blue-50 hover:bg-blue-100 text-blue-700 rounded-lg transition-colors border border-blue-200"
                >
                  📧 Email
                </button>
              </div>
            </div>
          </div>
        </div>
      )}

      {/* Aparência */}
      <div className="bg-white rounded-xl border border-gray-200 shadow-soft overflow-hidden">
        <button
          onClick={() => toggleSection('appearance')}
          className="w-full px-4 py-3 flex items-center justify-between hover:bg-gray-50 transition-colors"
        >
          <h3 className="text-sm font-semibold text-gray-900">Aparência</h3>
          {openSections.appearance ? (
            <FiChevronUp className="w-5 h-5 text-gray-500" />
          ) : (
            <FiChevronDown className="w-5 h-5 text-gray-500" />
          )}
        </button>
        {openSections.appearance && (
          <div className="px-4 pb-4 space-y-3">
            {/* Opacidade */}
            <div>
              <div className="flex items-center justify-between mb-2">
                <label className="block text-xs font-medium text-gray-600">Opacidade</label>
                <span className="text-xs font-semibold text-gray-900">
                  {Math.round((selectedElement.style.opacity ?? 1) * 100)}%
                </span>
              </div>
              <input
                type="range"
                min="0"
                max="100"
                value={Math.round((selectedElement.style.opacity ?? 1) * 100)}
                onChange={(e) => updateElementStyle(selectedElement.id, { opacity: Number(e.target.value) / 100 })}
                className="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-primary-500"
              />
            </div>

            {/* Cor de Fundo */}
            <div>
              <label className="block text-xs font-medium text-gray-600 mb-1.5">Cor de Fundo</label>
              <div className="flex gap-2">
                <input
                  type="color"
                  value={selectedElement.style.backgroundColor || '#FFFFFF'}
                  onChange={(e) => updateElementStyle(selectedElement.id, { backgroundColor: e.target.value })}
                  className="w-12 h-10 rounded-lg border border-gray-300 cursor-pointer shadow-soft"
                />
                <input
                  type="text"
                  value={selectedElement.style.backgroundColor || '#FFFFFF'}
                  onChange={(e) => updateElementStyle(selectedElement.id, { backgroundColor: e.target.value })}
                  className="flex-1 px-3 py-2 bg-gray-50 border border-gray-300 rounded-lg text-sm text-gray-900 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all font-mono uppercase"
                />
              </div>
            </div>

            {/* Espessura da Borda */}
            <div>
              <label className="block text-xs font-medium text-gray-600 mb-1.5">Espessura da Borda</label>
              <input
                type="number"
                value={selectedElement.style.borderWidth || 0}
                onChange={(e) => updateElementStyle(selectedElement.id, { borderWidth: Number(e.target.value) })}
                className="w-full px-3 py-2 bg-gray-50 border border-gray-300 rounded-lg text-sm text-gray-900 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all"
                placeholder="0"
              />
            </div>

            {/* Cor da Borda */}
            <div>
              <label className="block text-xs font-medium text-gray-600 mb-1.5">Cor da Borda</label>
              <div className="flex gap-2">
                <input
                  type="color"
                  value={selectedElement.style.borderColor || '#000000'}
                  onChange={(e) => updateElementStyle(selectedElement.id, { borderColor: e.target.value })}
                  className="w-12 h-10 rounded-lg border border-gray-300 cursor-pointer shadow-soft"
                />
                <input
                  type="text"
                  value={selectedElement.style.borderColor || '#000000'}
                  onChange={(e) => updateElementStyle(selectedElement.id, { borderColor: e.target.value })}
                  className="flex-1 px-3 py-2 bg-gray-50 border border-gray-300 rounded-lg text-sm text-gray-900 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all font-mono uppercase"
                />
              </div>
            </div>

            {/* Bordas Arredondadas */}
            <div>
              <label className="block text-xs font-medium text-gray-600 mb-1.5">Bordas Arredondadas</label>
              <input
                type="number"
                value={selectedElement.style.borderRadius || 0}
                onChange={(e) => updateElementStyle(selectedElement.id, { borderRadius: Number(e.target.value) })}
                className="w-full px-3 py-2 bg-gray-50 border border-gray-300 rounded-lg text-sm text-gray-900 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all"
                placeholder="0"
              />
            </div>
          </div>
        )}
      </div>

      {/* Image Upload/Selection Properties */}
      {(selectedElement.type === 'product-card' ||
        selectedElement.type === 'image' ||
        selectedElement.type === 'uploaded-image' ||
        selectedElement.type === 'banner' ||
        selectedElement.type === 'highlight-banner') && (() => {
          // Determinar a imagem atual baseado no tipo de elemento
          let currentImage = '';

          if (selectedElement.productData?.image) {
            currentImage = selectedElement.productData.image;
          } else if (selectedElement.highlightBannerData?.image) {
            currentImage = selectedElement.highlightBannerData.image;
          } else if (selectedElement.type === 'uploaded-image') {
            // Para uploaded-image, primeiro tenta buscar pelo assetId
            if (selectedElement.content?.assetId) {
              const asset = getAsset(selectedElement.content.assetId);
              console.log('🔍 Buscando asset:', {
                assetId: selectedElement.content.assetId,
                asset,
                url: asset?.url
              });
              currentImage = asset?.url || '';
            } else if (selectedElement.content?.imageUrl) {
              // Fallback para imageUrl se não tiver assetId
              console.log('🔍 Usando imageUrl direta:', selectedElement.content.imageUrl);
              currentImage = selectedElement.content.imageUrl;
            }
            console.log('🖼️ currentImage final:', currentImage);
          } else if (selectedElement.content?.imageUrl) {
            currentImage = selectedElement.content.imageUrl;
          }

          return (
            <div className="bg-white rounded-xl p-4 border border-gray-200 shadow-soft">
              <h3 className="text-xs font-semibold text-gray-900 mb-3 uppercase tracking-wide">Imagem</h3>
              <ImageSelector
                currentImage={currentImage}

                onImageSelect={(imageUrl) => {
                  if (selectedElement.type === 'product-card' && selectedElement.productData) {
                    updateElement(selectedElement.id, {
                      productData: {
                        ...selectedElement.productData,
                        image: imageUrl,
                      },
                    });
                  } else if (selectedElement.type === 'highlight-banner' && selectedElement.highlightBannerData) {
                    updateElement(selectedElement.id, {
                      highlightBannerData: {
                        ...selectedElement.highlightBannerData,
                        image: imageUrl,
                      },
                    });
                  } else if (selectedElement.type === 'uploaded-image') {
                    // Para uploaded-image, precisamos encontrar o asset pela URL
                    const asset = getAssetByUrl(imageUrl);
                    if (asset) {
                      // Se encontrou o asset, usa o assetId
                      updateElement(selectedElement.id, {
                        content: {
                          assetId: asset.id,
                        },
                      });
                    } else {
                      // Se não encontrou (ex: URL externa), salva a URL diretamente
                      updateElement(selectedElement.id, {
                        content: {
                          imageUrl,
                        },
                      });
                    }
                  } else {
                    updateElement(selectedElement.id, {
                      content: {
                        ...selectedElement.content,
                        imageUrl,
                      },
                    });
                  }
                }}
              />
            </div>
          );
        })()}

      {/* Image Editing Properties - Only for uploaded-image and image elements */}
      {(selectedElement.type === 'uploaded-image' || selectedElement.type === 'image') && (
        <div className="bg-white rounded-xl p-4 border border-gray-200 shadow-soft">
          <h3 className="text-xs font-semibold text-gray-900 mb-3 uppercase tracking-wide">Edição de Imagem</h3>
          <div className="space-y-3">
            {/* Object Fit */}
            <div>
              <label className="block text-xs font-medium text-gray-600 mb-1.5">Ajuste da Imagem</label>
              <select
                value={selectedElement.style?.objectFit || 'cover'}
                onChange={(e) => updateElementStyle(selectedElement.id, { objectFit: e.target.value as any })}
                className="w-full px-3 py-2 bg-gray-50 border border-gray-300 rounded-lg text-sm text-gray-900 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all"
              >
                <option value="cover">Preencher (Cover)</option>
                <option value="contain">Ajustar (Contain)</option>
                <option value="fill">Esticar (Fill)</option>
                <option value="none">Original (None)</option>
                <option value="scale-down">Reduzir (Scale Down)</option>
              </select>
            </div>

            {/* Brightness */}
            <div>
              <div className="flex items-center justify-between mb-2">
                <label className="block text-xs font-medium text-gray-600">Brilho</label>
                <span className="text-xs font-semibold text-gray-900">
                  {selectedElement.style?.brightness || 100}%
                </span>
              </div>
              <input
                type="range"
                min="0"
                max="200"
                value={selectedElement.style?.brightness || 100}
                onChange={(e) => updateElementStyle(selectedElement.id, { brightness: Number(e.target.value) })}
                className="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-primary-500"
              />
            </div>

            {/* Contrast */}
            <div>
              <div className="flex items-center justify-between mb-2">
                <label className="block text-xs font-medium text-gray-600">Contraste</label>
                <span className="text-xs font-semibold text-gray-900">
                  {selectedElement.style?.contrast || 100}%
                </span>
              </div>
              <input
                type="range"
                min="0"
                max="200"
                value={selectedElement.style?.contrast || 100}
                onChange={(e) => updateElementStyle(selectedElement.id, { contrast: Number(e.target.value) })}
                className="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-primary-500"
              />
            </div>

            {/* Saturation */}
            <div>
              <div className="flex items-center justify-between mb-2">
                <label className="block text-xs font-medium text-gray-600">Saturação</label>
                <span className="text-xs font-semibold text-gray-900">
                  {selectedElement.style?.saturate || 100}%
                </span>
              </div>
              <input
                type="range"
                min="0"
                max="200"
                value={selectedElement.style?.saturate || 100}
                onChange={(e) => updateElementStyle(selectedElement.id, { saturate: Number(e.target.value) })}
                className="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-primary-500"
              />
            </div>

            {/* Grayscale */}
            <div>
              <div className="flex items-center justify-between mb-2">
                <label className="block text-xs font-medium text-gray-600">Escala de Cinza</label>
                <span className="text-xs font-semibold text-gray-900">
                  {selectedElement.style?.grayscale || 0}%
                </span>
              </div>
              <input
                type="range"
                min="0"
                max="100"
                value={selectedElement.style?.grayscale || 0}
                onChange={(e) => updateElementStyle(selectedElement.id, { grayscale: Number(e.target.value) })}
                className="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-primary-500"
              />
            </div>

            {/* Blur */}
            <div>
              <div className="flex items-center justify-between mb-2">
                <label className="block text-xs font-medium text-gray-600">Desfoque</label>
                <span className="text-xs font-semibold text-gray-900">
                  {selectedElement.style?.blur || 0}px
                </span>
              </div>
              <input
                type="range"
                min="0"
                max="20"
                value={selectedElement.style?.blur || 0}
                onChange={(e) => updateElementStyle(selectedElement.id, { blur: Number(e.target.value) })}
                className="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-primary-500"
              />
            </div>

            {/* Reset Filters Button */}
            <button
              onClick={() => {
                updateElementStyle(selectedElement.id, {
                  brightness: 100,
                  contrast: 100,
                  saturate: 100,
                  grayscale: 0,
                  blur: 0,
                });
              }}
              className="w-full flex items-center justify-center gap-2 px-4 py-2.5 bg-gradient-to-r from-gray-600 to-gray-700 text-white rounded-xl hover:from-gray-700 hover:to-gray-800 transition-all shadow-soft hover:shadow-medium"
            >
              Resetar Filtros
            </button>
          </div>
        </div>
      )}

      {/* Product Card Properties */}
      {selectedElement.type === 'product-card' && selectedElement.productData && (
        <div className="bg-white rounded-xl p-4 border border-gray-200 shadow-soft">
          <h3 className="text-xs font-semibold text-gray-900 mb-3 uppercase tracking-wide">Informações do Produto</h3>
          <div className="space-y-3">
            <div>
              <label className="block text-xs font-medium text-gray-600 mb-1.5">Nome do Produto</label>
              <input
                type="text"
                value={selectedElement.productData.name}
                onChange={(e) =>
                  updateElement(selectedElement.id, {
                    productData: {
                      ...selectedElement.productData!,
                      name: e.target.value,
                    },
                  })
                }
                className="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all"
              />
            </div>
            <div>
              <label className="block text-xs font-medium text-gray-600 mb-1.5">Preço</label>
              <input
                type="number"
                step="0.01"
                value={selectedElement.productData.price}
                onChange={(e) =>
                  updateElement(selectedElement.id, {
                    productData: {
                      ...selectedElement.productData!,
                      price: Number(e.target.value),
                    },
                  })
                }
                className="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all"
              />
            </div>
            <div>
              <label className="block text-xs font-medium text-gray-600 mb-1.5">Descrição</label>
              <textarea
                value={selectedElement.productData.description || ''}
                onChange={(e) =>
                  updateElement(selectedElement.id, {
                    productData: {
                      ...selectedElement.productData!,
                      description: e.target.value,
                    },
                  })
                }
                className="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all resize-none"
                rows={3}
                placeholder="Descrição do produto..."
              />
            </div>
          </div>
        </div>
      )}

      {/* QR Code Properties */}
      {selectedElement.type === 'qr-code' && selectedElement.qrCodeData && (
        <div className="bg-white rounded-xl p-4 border border-gray-200 shadow-soft">
          <h3 className="text-xs font-semibold text-gray-900 mb-3 uppercase tracking-wide">Configurações do QR Code</h3>
          <div className="space-y-4">
            <div>
              <label className="block text-xs font-medium text-gray-600 mb-1.5">
                URL ou Texto
              </label>
              <input
                type="text"
                value={selectedElement.qrCodeData.data || ''}
                onChange={(e) =>
                  updateElement(selectedElement.id, {
                    qrCodeData: {
                      ...selectedElement.qrCodeData!,
                      data: e.target.value,
                    },
                  })
                }
                placeholder="https://exemplo.com"
                className="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all"
              />
              <p className="text-xs text-gray-500 mt-1.5">
                Digite uma URL ou qualquer texto
              </p>
            </div>

            <div>
              <label className="block text-xs font-medium text-gray-600 mb-1.5">
                Cor do QR Code
              </label>
              <div className="flex gap-2">
                <input
                  type="color"
                  value={selectedElement.qrCodeData.color || '#000000'}
                  onChange={(e) =>
                    updateElement(selectedElement.id, {
                      qrCodeData: {
                        ...selectedElement.qrCodeData!,
                        color: e.target.value,
                      },
                    })
                  }
                  className="w-12 h-10 rounded-lg border border-gray-300 cursor-pointer shadow-soft"
                />
                <input
                  type="text"
                  value={selectedElement.qrCodeData.color || '#000000'}
                  onChange={(e) =>
                    updateElement(selectedElement.id, {
                      qrCodeData: {
                        ...selectedElement.qrCodeData!,
                        color: e.target.value,
                      },
                    })
                  }
                  className="flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all font-mono uppercase"
                />
              </div>
            </div>

            <div>
              <label className="block text-xs text-gray-600 mb-1 font-medium">
                Cor de Fundo
              </label>
              <div className="flex gap-2">
                <input
                  type="color"
                  value={selectedElement.qrCodeData.backgroundColor || '#FFFFFF'}
                  onChange={(e) =>
                    updateElement(selectedElement.id, {
                      qrCodeData: {
                        ...selectedElement.qrCodeData!,
                        backgroundColor: e.target.value,
                      },
                    })
                  }
                  className="w-12 h-10 rounded border cursor-pointer"
                />
                <input
                  type="text"
                  value={selectedElement.qrCodeData.backgroundColor || '#FFFFFF'}
                  onChange={(e) =>
                    updateElement(selectedElement.id, {
                      qrCodeData: {
                        ...selectedElement.qrCodeData!,
                        backgroundColor: e.target.value,
                      },
                    })
                  }
                  className="flex-1 px-3 py-2 border rounded-lg text-sm"
                />
              </div>
            </div>

            <div>
              <label className="block text-xs text-gray-600 mb-1 font-medium">
                Nível de Correção de Erro
              </label>
              <select
                value={selectedElement.qrCodeData.errorCorrection || 'M'}
                onChange={(e) =>
                  updateElement(selectedElement.id, {
                    qrCodeData: {
                      ...selectedElement.qrCodeData!,
                      errorCorrection: e.target.value as 'L' | 'M' | 'Q' | 'H',
                    },
                  })
                }
                className="w-full px-3 py-2 border rounded-lg text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
              >
                <option value="L">Baixo (7%)</option>
                <option value="M">Médio (15%)</option>
                <option value="Q">Alto (25%)</option>
                <option value="H">Muito Alto (30%)</option>
              </select>
              <p className="text-xs text-gray-500 mt-1">
                Maior correção permite adicionar logo
              </p>
            </div>

            <div>
              <label className="block text-xs text-gray-600 mb-1 font-medium">
                Logo Central (URL da imagem)
              </label>
              <input
                type="text"
                value={selectedElement.qrCodeData.logo || ''}
                onChange={(e) =>
                  updateElement(selectedElement.id, {
                    qrCodeData: {
                      ...selectedElement.qrCodeData!,
                      logo: e.target.value,
                    },
                  })
                }
                placeholder="https://exemplo.com/logo.png"
                className="w-full px-3 py-2 border rounded-lg text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
              />
              <p className="text-xs text-gray-500 mt-1">
                Opcional: Logo no centro do QR Code
              </p>
            </div>

            {/* Quick URL Templates */}
            <div>
              <label className="block text-xs text-gray-600 mb-2 font-medium">
                Modelos Rápidos
              </label>
              <div className="grid grid-cols-2 gap-2">
                <button
                  onClick={() =>
                    updateElement(selectedElement.id, {
                      qrCodeData: {
                        ...selectedElement.qrCodeData!,
                        data: 'https://www.seusite.com',
                      },
                    })
                  }
                  className="px-3 py-2 text-xs bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors"
                >
                  🌐 Website
                </button>
                <button
                  onClick={() =>
                    updateElement(selectedElement.id, {
                      qrCodeData: {
                        ...selectedElement.qrCodeData!,
                        data: 'mailto:contato@empresa.com',
                      },
                    })
                  }
                  className="px-3 py-2 text-xs bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors"
                >
                  📧 Email
                </button>
                <button
                  onClick={() =>
                    updateElement(selectedElement.id, {
                      qrCodeData: {
                        ...selectedElement.qrCodeData!,
                        data: 'tel:+5511999999999',
                      },
                    })
                  }
                  className="px-3 py-2 text-xs bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors"
                >
                  📱 Telefone
                </button>
                <button
                  onClick={() =>
                    updateElement(selectedElement.id, {
                      qrCodeData: {
                        ...selectedElement.qrCodeData!,
                        data: 'https://wa.me/5511999999999',
                      },
                    })
                  }
                  className="px-3 py-2 text-xs bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors"
                >
                  💬 WhatsApp
                </button>
              </div>
            </div>
          </div>
        </div>
      )}

      {/* Text Properties */}
      {selectedElement.type.includes('text') && (
        <div className="bg-white rounded-xl p-4 border border-gray-200 shadow-soft">
          <h3 className="text-xs font-semibold text-gray-900 mb-3 uppercase tracking-wide">Tipografia</h3>
          <div className="space-y-3">
            <div>
              <label className="block text-xs font-medium text-gray-600 mb-1.5">Tamanho da Fonte</label>
              <input
                type="number"
                value={selectedElement.style.fontSize || 16}
                onChange={(e) => updateElementStyle(selectedElement.id, { fontSize: Number(e.target.value) })}
                className="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all"
                placeholder="16 px"
              />
            </div>
            <div>
              <label className="block text-xs font-medium text-gray-600 mb-1.5">Cor do Texto</label>
              <div className="flex gap-2">
                <input
                  type="color"
                  value={selectedElement.style.textColor || '#1F2937'}
                  onChange={(e) => updateElementStyle(selectedElement.id, { textColor: e.target.value })}
                  className="w-12 h-10 rounded-lg border border-gray-300 cursor-pointer shadow-soft"
                />
                <input
                  type="text"
                  value={selectedElement.style.textColor || '#1F2937'}
                  onChange={(e) => updateElementStyle(selectedElement.id, { textColor: e.target.value })}
                  className="flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all font-mono uppercase"
                />
              </div>
            </div>
          </div>
        </div>
      )}

      {/* Info */}
      <div className="bg-white rounded-xl border border-gray-200 shadow-soft overflow-hidden">
        <button
          onClick={() => toggleSection('info')}
          className="w-full px-4 py-3 flex items-center justify-between hover:bg-gray-50 transition-colors"
        >
          <h3 className="text-sm font-semibold text-gray-900">Info</h3>
          {openSections.info ? (
            <FiChevronUp className="w-5 h-5 text-gray-500" />
          ) : (
            <FiChevronDown className="w-5 h-5 text-gray-500" />
          )}
        </button>
        {openSections.info && (
          <div className="px-4 pb-4 space-y-3">
            <div>
              <label className="block text-xs font-medium text-gray-600 mb-1.5">ID do Elemento</label>
              <div className="px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg text-xs font-mono text-gray-700">
                {selectedElement.id}
              </div>
            </div>
            <div>
              <label className="block text-xs font-medium text-gray-600 mb-1.5">Tipo</label>
              <div className="px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg text-xs font-medium text-gray-700 capitalize">
                {selectedElement.type.replace(/-/g, ' ')}
              </div>
            </div>
            <div className="grid grid-cols-2 gap-3">
              <div>
                <label className="block text-xs font-medium text-gray-600 mb-1.5">Z-Index</label>
                <div className="px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg text-xs font-medium text-gray-700">
                  {selectedElement.zIndex || 0}
                </div>
              </div>
              <div>
                <label className="block text-xs font-medium text-gray-600 mb-1.5">Rotação</label>
                <div className="px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg text-xs font-medium text-gray-700">
                  {selectedElement.rotation || 0}°
                </div>
              </div>
            </div>
          </div>
        )}
      </div>

      {/* Actions */}
      <div className="flex gap-2 pt-2">
        <button
          onClick={() => duplicateElement(selectedElement.id)}
          className="flex-1 flex items-center justify-center gap-2 px-4 py-2.5 bg-gradient-to-r from-gray-700 to-gray-800 text-white rounded-xl hover:from-gray-800 hover:to-gray-900 transition-all shadow-soft hover:shadow-medium"
        >
          <FiCopy className="w-4 h-4" />
          Duplicar
        </button>
        <button
          onClick={() => deleteElement(selectedElement.id)}
          className="flex-1 flex items-center justify-center gap-2 px-4 py-2.5 bg-gradient-to-r from-red-500 to-red-600 text-white rounded-xl hover:from-red-600 hover:to-red-700 transition-all shadow-soft hover:shadow-medium"
        >
          <FiTrash2 className="w-4 h-4" />
          Excluir
        </button>
      </div>
    </div>
  );
};
