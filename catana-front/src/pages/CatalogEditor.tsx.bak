import { type FC, useState, useEffect } from 'react';
import { EditorHeader } from '../components/editor/EditorHeader';
import { PhotoshopToolbar } from '../components/editor/PhotoshopToolbar';
import { PhotoshopSidebar } from '../components/editor/PhotoshopSidebar';
import { InfiniteCanvas } from '../components/editor/InfiniteCanvas';
import { PDFPreviewModal } from '../components/editor/PDFPreviewModal';
import { PagesManagerModal } from '../components/editor/PagesManagerModal';
import { SaveComponentModal } from '../components/editor/SaveComponentModal';
import { LayersPanel } from '../components/editor/LayersPanel';
import { GroupsPanel } from '../components/editor/GroupsPanel';
import { MinimizedPanelTabs } from '../components/editor/MinimizedPanelTabs';
import { AlignmentToolbar } from '../components/editor/AlignmentToolbar';
import { ShortcutsPanel, ShortcutsButton } from '../components/editor/ShortcutsPanel';
import { PanelProvider } from '../contexts/PanelContext';
import { UIProvider, useUIContext } from '../contexts/UIContext';
import { useEditorShortcuts } from '../hooks/useKeyboardShortcuts';
import { useEditorStore } from '../store/editorStore';
import { useAssetStore } from '../store/assetStore';
import html2canvas from 'html2canvas';
import jsPDF from 'jspdf';
import {
  alignElements,
  distributeElements,
  matchSize,
  arrangeInGrid,
} from '../utils/alignmentHelpers';

const CatalogEditorContent: FC = () => {
  const [showPDFPreview, setShowPDFPreview] = useState(false);
  const [showPagesManager, setShowPagesManager] = useState(false);
  const [showSaveComponent, setShowSaveComponent] = useState(false);
  const [showShortcuts, setShowShortcuts] = useState(false);
  const [showPhotoshopSidebar, setShowPhotoshopSidebar] = useState(true);
  const [activeTab, setActiveTab] = useState<'layers' | 'properties'>('properties');
  const [isDownloadingPDF, setIsDownloadingPDF] = useState(false);
  const { uiVisible } = useUIContext();

  const {
    pages,
    selectedElementIds,
    updateElement,
    deleteElement,
    duplicateElement,
    toggleGrid,
    toggleSnapToGrid,
    undo,
    redo,
    catalogName,
  } = useEditorStore();

  const { getAsset } = useAssetStore();

  const currentPage = pages.find(p => p.id === useEditorStore.getState().currentPageId);
  const selectedElements = currentPage?.elements.filter(el =>
    selectedElementIds.includes(el.id)
  ) || [];

  // Alignment handlers
  const handleAlign = (alignType: 'left' | 'center' | 'right' | 'top' | 'middle' | 'bottom') => {
    const updates = alignElements(selectedElements, alignType);
    updates.forEach((position, id) => {
      updateElement(id, { position });
    });
  };

  const handleDistribute = (type: 'horizontal' | 'vertical') => {
    const updates = distributeElements(selectedElements, type);
    updates.forEach((position, id) => {
      updateElement(id, { position });
    });
  };

  const handleMatchSize = (dimension: 'width' | 'height' | 'both') => {
    const updates = matchSize(selectedElements, dimension);
    updates.forEach((size, id) => {
      updateElement(id, { size });
    });
  };

  const handleArrangeGrid = () => {
    const columns = Math.ceil(Math.sqrt(selectedElements.length));
    const updates = arrangeInGrid(selectedElements, columns, 20);
    updates.forEach((position, id) => {
      updateElement(id, { position });
    });
  };

  // Função para download direto de PDF - agora abre o modal com opções de exportação
  const handleDownloadPDF = () => {
    // Abre o modal de preview com as opções de exportação
    setShowPDFPreview(true);
    // O modal já abrirá com o botão "Exportar (Recomendado)" visível
  }; // Aumentado para garantir renderização completa

    try {
      const pdf = new jsPDF({
        orientation: 'portrait',
        unit: 'mm',
        format: 'a4',
      });

      const pageElements = document.querySelectorAll('.pdf-page-content');

      if (pageElements.length === 0) {
        alert('Nenhuma página encontrada para gerar o PDF.');
        setShowPDFPreview(false);
        setIsDownloadingPDF(false);
        return;
      }

      for (let i = 0; i < pageElements.length; i++) {
        const element = pageElements[i] as HTMLElement;

        // Forçar conversão de cores oklch para RGB antes de renderizar
        const allElements = element.querySelectorAll('*');
        const originalStyles = new Map();

        allElements.forEach((el) => {
          const htmlEl = el as HTMLElement;
          const computedStyle = window.getComputedStyle(htmlEl);

          // Salvar estilos originais e converter oklch para RGB
          ['color', 'backgroundColor', 'borderColor'].forEach(prop => {
            const value = computedStyle.getPropertyValue(prop);
            if (value && value.includes('oklch')) {
              originalStyles.set({ el: htmlEl, prop }, value);
              // Converter para RGB usando getComputedStyle que já calcula o valor final
              const rgb = computedStyle.getPropertyValue(prop);
              htmlEl.style.setProperty(prop, rgb, 'important');
            }
          });
        });

        const canvas = await html2canvas(element, {
          scale: 6, // Máxima qualidade - 6x de resolução (3168x4482 pixels)
          useCORS: true,
          allowTaint: true,
          backgroundColor: '#ffffff',
          logging: false,
          imageTimeout: 0,
          removeContainer: true,
          windowWidth: element.scrollWidth,
          windowHeight: element.scrollHeight,
          onclone: (clonedDoc) => {
            // Função para converter oklch/oklab/hsl para RGB
            const convertColorToRgb = (colorStr: string): string => {
              // Mapa de cores DiPACK e Tailwind comuns
              const colorMap: { [key: string]: string } = {
                // Cores primárias DiPACK (bege rosado)
                'hsl(20 35% 58%)': '#c79d89', // primary-500
                'hsl(20 17% 72%)': '#d9c6ba', // primary clara
                'rgb(199, 157, 137)': '#c79d89', // primary-500
                'rgb(217, 198, 186)': '#d9c6ba',
                'rgb(184, 137, 113)': '#b88971', // primary-600
                'rgb(154, 111, 90)': '#9a6f5a',  // primary-700
                'rgb(221, 197, 185)': '#ddc5b9', // primary-300
                'rgb(210, 177, 161)': '#d2b1a1', // primary-400
                'rgb(124, 85, 67)': '#7c5543',   // primary-800
                'rgb(94, 59, 44)': '#5e3b2c',    // primary-900

                // Cores neutras DiPACK
                'hsl(0 0% 95%)': '#f2f2f2', // foreground claro
                'hsl(0 0% 12%)': '#1f1f1f', // card escuro
                'hsl(0 0% 8%)': '#141414',  // background escuro
                'hsl(0 0% 20%)': '#333333', // border
                'hsl(0 5% 25%)': '#3d3d3d', // secondary
                'hsl(0 2% 54%)': '#89888c', // neutral-500
                'rgb(250, 250, 250)': '#fafafa', // neutral-50
                'rgb(245, 245, 245)': '#f5f5f5', // neutral-100
                'rgb(229, 229, 229)': '#e5e5e5', // neutral-200
                'rgb(212, 212, 212)': '#d4d4d4', // neutral-300
                'rgb(115, 115, 115)': '#737373', // neutral-600
                'rgb(82, 82, 82)': '#525252',    // neutral-700
                'rgb(64, 64, 64)': '#404040',    // neutral-800
                'rgb(38, 38, 38)': '#262626',    // neutral-900
                'rgb(13, 13, 13)': '#0d0d0d',    // neutral-950

                // Amarelos e âmbares (Tailwind yellow/amber)
                'oklch(0.949 0.093 102.2)': '#fef08a', // yellow-200
                'oklch(0.912 0.151 101.2)': '#fde047', // yellow-300
                'oklch(0.881 0.184 99.6)': '#facc15', // yellow-400
                'oklch(0.809 0.185 95.4)': '#eab308', // yellow-500
                'oklch(0.725 0.174 89.9)': '#ca8a04', // yellow-600
                'oklch(0.944 0.117 101.4)': '#fcd34d', // amber-300
                'oklch(0.882 0.157 97.6)': '#fbbf24', // amber-400
                'oklch(0.802 0.159 91.5)': '#f59e0b', // amber-500
                'oklch(0.713 0.154 84.8)': '#d97706', // amber-600

                // Cinzas oklch
                'oklch(0.988 0 none)': '#fafafa', // gray-50
                'oklch(0.962 0 none)': '#f5f5f5', // gray-100
                'oklch(0.902 0 none)': '#e5e5e5', // gray-200
                'oklch(0.302 0 none)': '#404040', // gray-800
                'oklch(0.221 0 none)': '#262626', // gray-900
                'oklch(0.167 0 none)': '#0d0d0d', // gray-950
              };

              // Normalizar string removendo espaços extras
              const normalized = colorStr.trim().replace(/\s+/g, ' ');

              // Tentar encontrar correspondência exata
              if (colorMap[normalized]) {
                return colorMap[normalized];
              }

              // Converter HSL para RGB (formato: hsl(h s% l%) ou hsl(h s l))
              const hslMatch = colorStr.match(/hsl\(\s*([\d.]+)\s+([\d.]+)%?\s+([\d.]+)%?(?:\s*\/\s*([\d.]+%?))?\s*\)/);
              if (hslMatch) {
                const h = parseFloat(hslMatch[1]);
                const s = parseFloat(hslMatch[2]) / 100;
                const l = parseFloat(hslMatch[3]) / 100;

                // Converter HSL para RGB
                const c = (1 - Math.abs(2 * l - 1)) * s;
                const x = c * (1 - Math.abs(((h / 60) % 2) - 1));
                const m = l - c / 2;

                let r = 0, g = 0, b = 0;
                if (h < 60) { r = c; g = x; b = 0; }
                else if (h < 120) { r = x; g = c; b = 0; }
                else if (h < 180) { r = 0; g = c; b = x; }
                else if (h < 240) { r = 0; g = x; b = c; }
                else if (h < 300) { r = x; g = 0; b = c; }
                else { r = c; g = 0; b = x; }

                const toHex = (n: number) => {
                  const hex = Math.round((n + m) * 255).toString(16);
                  return hex.length === 1 ? '0' + hex : hex;
                };

                return `#${toHex(r)}${toHex(g)}${toHex(b)}`;
              }

              // Converter RGB para hex (formato: rgb(r, g, b) ou rgb(r g b))
              const rgbMatch = colorStr.match(/rgb\(\s*(\d+)\s*,?\s*(\d+)\s*,?\s*(\d+)\s*\)/);
              if (rgbMatch) {
                const r = parseInt(rgbMatch[1]);
                const g = parseInt(rgbMatch[2]);
                const b = parseInt(rgbMatch[3]);
                const toHex = (n: number) => {
                  const hex = n.toString(16);
                  return hex.length === 1 ? '0' + hex : hex;
                };
                return `#${toHex(r)}${toHex(g)}${toHex(b)}`;
              }

              // Converter oklab para RGB (formato: oklab(L a b / alpha))
              const oklabMatch = colorStr.match(/oklab\(([\d.]+)\s+([\d.-]+)\s+([\d.-]+)(?:\s*\/\s*([\d.]+%?))?\)/);
              if (oklabMatch) {
                const [, l] = oklabMatch;
                const lightness = parseFloat(l);

                // Conversão simplificada baseada em luminosidade
                if (lightness > 0.9) return '#f5f5f5'; // claro
                if (lightness > 0.8) return '#e5e5e5'; // cinza claro
                if (lightness > 0.7) return '#737373'; // cinza médio
                if (lightness > 0.5) return '#525252'; // cinza médio-escuro
                if (lightness > 0.3) return '#404040'; // cinza escuro
                return '#262626'; // muito escuro
              }

              // Converter oklch para RGB (formato: oklch(L C H / alpha))
              const oklchMatch = colorStr.match(/oklch\(([\d.]+)\s+([\d.]+)\s+([\d.]+)(?:\s*\/\s*([\d.]+%?))?\)/);
              if (oklchMatch) {
                const [, l, c, h] = oklchMatch;
                const lightness = parseFloat(l);
                const chroma = parseFloat(c);
                const hue = parseFloat(h);

                // Conversão baseada em luminosidade, croma e matiz
                // Matiz ~20 = tons rosados/bege (DiPACK)
                if (hue >= 15 && hue <= 25 && chroma > 0.1) {
                  if (lightness > 0.7) return '#d9c6ba'; // primary claro
                  if (lightness > 0.6) return '#c79d89'; // primary
                  if (lightness > 0.5) return '#b88971'; // primary-600
                  return '#9a6f5a'; // primary-700
                }

                // Outros matizes
                if (lightness > 0.9) return '#f5f5f5'; // claro
                if (lightness > 0.8) return chroma > 0.1 ? '#facc15' : '#e5e5e5'; // amarelo claro ou cinza claro
                if (lightness > 0.7) return chroma > 0.1 ? '#eab308' : '#737373'; // amarelo médio ou cinza médio
                if (lightness > 0.5) return chroma > 0.1 ? '#c79d89' : '#525252'; // bege ou cinza
                if (lightness > 0.3) return '#404040'; // cinza escuro
                return '#262626'; // muito escuro
              }

              // Fallback - retornar cinza médio
              return '#808080';
            };

            // Substituir TODAS as ocorrências de oklch/oklab/hsl no documento
            const clonedElements = clonedDoc.querySelectorAll('*');
            clonedElements.forEach((el) => {
              const htmlEl = el as HTMLElement;

              // Obter estilos inline
              const inlineStyle = htmlEl.getAttribute('style') || '';
              if (inlineStyle.includes('oklch') || inlineStyle.includes('oklab') || inlineStyle.includes('hsl(')) {
                const newStyle = inlineStyle
                  .replace(/oklch\([^)]+\)/g, (match) => convertColorToRgb(match))
                  .replace(/oklab\([^)]+\)/g, (match) => convertColorToRgb(match))
                  .replace(/hsl\([^)]+\)/g, (match) => convertColorToRgb(match));
                htmlEl.setAttribute('style', newStyle);
              }

              // Processar computed styles
              const computedStyle = clonedDoc.defaultView?.getComputedStyle(htmlEl);
              if (computedStyle) {
                // Background-image (gradientes)
                const bgImage = computedStyle.backgroundImage;
                if (bgImage && bgImage !== 'none' && (bgImage.includes('oklch') || bgImage.includes('oklab') || bgImage.includes('hsl('))) {
                  const newBgImage = bgImage
                    .replace(/oklch\([^)]+\)/g, (match) => convertColorToRgb(match))
                    .replace(/oklab\([^)]+\)/g, (match) => convertColorToRgb(match))
                    .replace(/hsl\([^)]+\)/g, (match) => convertColorToRgb(match));
                  htmlEl.style.backgroundImage = newBgImage;
                }

                // Background-color
                const bgColor = computedStyle.backgroundColor;
                if (bgColor) {
                  const convertedBgColor = convertColorToRgb(bgColor);
                  if (convertedBgColor !== '#808080') { // Evitar sobrescrever com fallback
                    htmlEl.style.backgroundColor = convertedBgColor;
                  }
                }

                // Color (texto)
                const color = computedStyle.color;
                if (color) {
                  const convertedColor = convertColorToRgb(color);
                  if (convertedColor !== '#808080') { // Evitar sobrescrever com fallback
                    htmlEl.style.color = convertedColor;
                  }
                }

                // Border-color
                const borderColor = computedStyle.borderColor;
                if (borderColor && borderColor !== 'rgba(0, 0, 0, 0)') {
                  const convertedBorderColor = convertColorToRgb(borderColor);
                  if (convertedBorderColor !== '#808080') { // Evitar sobrescrever com fallback
                    htmlEl.style.borderColor = convertedBorderColor;
                  }
                }

                // Box-shadow
                const boxShadow = computedStyle.boxShadow;
                if (boxShadow && boxShadow !== 'none' && (boxShadow.includes('oklch') || boxShadow.includes('oklab') || boxShadow.includes('hsl('))) {
                  const newBoxShadow = boxShadow
                    .replace(/oklch\([^)]+\)/g, (match) => convertColorToRgb(match))
                    .replace(/oklab\([^)]+\)/g, (match) => convertColorToRgb(match))
                    .replace(/hsl\([^)]+\)/g, (match) => convertColorToRgb(match));
                  htmlEl.style.boxShadow = newBoxShadow;
                }
              }
            });

            // Substituir cores oklch/oklab/hsl em todos os <style> tags
            const styleTags = clonedDoc.querySelectorAll('style');
            styleTags.forEach((styleTag) => {
              if (styleTag.textContent && (styleTag.textContent.includes('oklch') || styleTag.textContent.includes('oklab') || styleTag.textContent.includes('hsl('))) {
                styleTag.textContent = styleTag.textContent
                  .replace(/oklch\([^)]+\)/g, (match) => convertColorToRgb(match))
                  .replace(/oklab\([^)]+\)/g, (match) => convertColorToRgb(match))
                  .replace(/hsl\([^)]+\)/g, (match) => convertColorToRgb(match));
              }
            });
          }
        });

        // Restaurar estilos originais
        originalStyles.forEach((value, key) => {
          key.el.style.setProperty(key.prop, value);
        });

        // Converter para PNG sem compressão - máxima fidelidade visual
        const imgData = canvas.toDataURL('image/png');

        // Dimensões exatas do A4 em mm
        const pdfWidth = 210;
        const pdfHeight = 297;

        if (i > 0) {
          pdf.addPage();
        }

        // Adicionar imagem PNG em altíssima qualidade, sem compressão
        pdf.addImage(imgData, 'PNG', 0, 0, pdfWidth, pdfHeight, undefined, 'NONE');
      }

      const fileName = `${String(catalogName || 'catalogo')}.pdf`;
      pdf.save(fileName);

      // Fechar o modal após o download
      setShowPDFPreview(false);
    } catch (error) {
      console.error('Erro ao gerar PDF:', error);
      alert('Erro ao gerar PDF. Por favor, tente novamente.');
      setShowPDFPreview(false);
    } finally {
      setIsDownloadingPDF(false);
    }
  };

  // Escutar evento de duplo clique para abrir painel de propriedades
  useEffect(() => {
    const handleOpenPropertiesPanel = () => {
      setActiveTab('properties');
      if (!showPhotoshopSidebar) {
        setShowPhotoshopSidebar(true);
      }
    };

    window.addEventListener('openPropertiesPanel', handleOpenPropertiesPanel);
    return () => {
      window.removeEventListener('openPropertiesPanel', handleOpenPropertiesPanel);
    };
  }, [showPhotoshopSidebar]);

  // Keyboard shortcuts
  useEditorShortcuts({
    onCopy: () => console.log('Copy'),
    onPaste: () => console.log('Paste'),
    onDuplicate: () => selectedElementIds.forEach(id => duplicateElement(id)),
    onDelete: () => selectedElementIds.forEach(id => deleteElement(id)),
    onUndo: undo,
    onRedo: redo,
    onToggleGrid: toggleGrid,
    onToggleSnap: toggleSnapToGrid,
    onToggleElements: () => setShowElementsSidebar(!showElementsSidebar),
    onAlignLeft: () => handleAlign('left'),
    onAlignCenter: () => handleAlign('center'),
    onAlignRight: () => handleAlign('right'),
    onAlignTop: () => handleAlign('top'),
    onAlignMiddle: () => handleAlign('middle'),
    onAlignBottom: () => handleAlign('bottom'),
  });

  return (
    <div className="h-screen w-screen overflow-hidden bg-gray-50">
      {/* Header */}
      {uiVisible && (
        <EditorHeader
          onShowPreview={() => { setShowPDFPreview(true); }}
          onShowPagesManager={() => { setShowPagesManager(true); }}
          onDownloadPDF={handleDownloadPDF}
        />
      )}

      {/* Main Layout */}
      <div className={`flex h-full ${uiVisible ? 'pt-14' : ''}`}>
        {/* Photoshop-style Toolbar */}
        {uiVisible && (
          <PhotoshopToolbar
            onShowPreview={() => setShowPDFPreview(true)}
            onSaveComponent={() => setShowSaveComponent(true)}
            onToggleSidebar={() => setShowPhotoshopSidebar(!showPhotoshopSidebar)}
            isSidebarVisible={showPhotoshopSidebar}
          />
        )}

        {/* Canvas - Full screen with left margin for toolbar */}
        <div className={`absolute inset-0 ${uiVisible ? 'top-14 left-16' : 'top-0 left-0'}`}>
          <InfiniteCanvas />
        </div>

        {/* Right Sidebar - Properties (DESABILITADO - movido para PhotoshopSidebar) */}
        {/* {uiVisible && <PropertiesPanel />} */}
      </div>

      {/* PDF Preview Modal */}
      <PDFPreviewModal isOpen={showPDFPreview} onClose={() => setShowPDFPreview(false)} />

      {/* Pages Manager Modal */}
      <PagesManagerModal isOpen={showPagesManager} onClose={() => setShowPagesManager(false)} />

      {/* Save Component Modal */}
      <SaveComponentModal isOpen={showSaveComponent} onClose={() => setShowSaveComponent(false)} />

      {/* Layers Panel */}
      {uiVisible && <LayersPanel />}

      {/* Groups Panel */}
      {uiVisible && <GroupsPanel />}

      {/* Minimized Panel Tabs */}
      {uiVisible && <MinimizedPanelTabs />}

      {/* NEW: Alignment Toolbar */}
      {uiVisible && (
        <AlignmentToolbar
          selectedCount={selectedElementIds.length}
          onAlign={handleAlign}
          onDistribute={handleDistribute}
          onMatchSize={handleMatchSize}
          onArrangeGrid={handleArrangeGrid}
        />
      )}

      {/* NEW: Shortcuts Panel */}
      {showShortcuts && (
        <ShortcutsPanel
          shortcuts={getAllShortcuts()}
          isOpen={showShortcuts}
          onClose={() => setShowShortcuts(false)}
        />
      )}

      {/* NEW: Shortcuts Button */}
      {uiVisible && <ShortcutsButton onClick={() => setShowShortcuts(true)} />}

      {/* NEW: Photoshop-style Sidebar */}
      {uiVisible && showPhotoshopSidebar && (
        <PhotoshopSidebar
          side="right"
          defaultTab={activeTab}
          onClose={() => setShowPhotoshopSidebar(false)}
        />
      )}
    </div>
  );
};

// Helper function to get all shortcuts for the panel
function getAllShortcuts() {
  return [
    // Basic editing
    { key: 'c', ctrl: true, description: 'Copiar' },
    { key: 'd', ctrl: true, description: 'Duplicar' },
    { key: 'Delete', description: 'Deletar' },
    // History
    { key: 'z', ctrl: true, description: 'Desfazer' },
    { key: 'y', ctrl: true, description: 'Refazer' },
    // Alignment
    { key: 'l', ctrl: true, shift: true, description: 'Alinhar à esquerda' },
    { key: 'c', ctrl: true, shift: true, description: 'Centralizar horizontalmente' },
    { key: 'r', ctrl: true, shift: true, description: 'Alinhar à direita' },
    { key: 't', ctrl: true, shift: true, description: 'Alinhar ao topo' },
    { key: 'm', ctrl: true, shift: true, description: 'Centralizar verticalmente' },
    { key: 'b', ctrl: true, shift: true, description: 'Alinhar à base' },
    // UI Panels
    { key: 'e', ctrl: true, description: 'Alternar painel de elementos' },
    // Grid
    { key: "'", ctrl: true, description: 'Alternar grade' },
  ].map(s => ({ ...s, action: () => {} }));
}

export const CatalogEditor: FC = () => {
  return (
    <UIProvider>
      <PanelProvider>
        <CatalogEditorContent />
      </PanelProvider>
    </UIProvider>
  );
};
